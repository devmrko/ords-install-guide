# ============================================================
# .env.example  →  cp .env.example .env  후 값 채워서 사용
# 모든 run.sh / scripts/*.sh / terraform 래퍼가 이 파일을 source 합니다.
# 절대 .env 자체를 git에 올리지 마세요 (.gitignore에 등록됨).
# ============================================================

# --- OS / 설치 경로 ---
ORDS_USER=oracle
ORDS_GROUP=oinstall

# JDK / ORDS 는 'current' alias 패턴 — 업그레이드 시 symlink만 갈아끼움
JAVA_HOME=/opt/java/current
ORDS_HOME=/opt/oracle/ords/current
ORDS_CONFIG=/etc/ords/config         # ords --config 대상 (생성됨)

# --- 다운로드 소스 (latest alias; 운영 동결 시 버전 변수 풀어서 사용) ---
ORDS_URL=https://download.oracle.com/otn_software/java/ords/ords-latest.zip
SQLCL_URL=https://download.oracle.com/otn_software/java/sqldeveloper/sqlcl-latest.zip
# 버전 고정용 (필요 시):
# ORDS_VERSION=24.3.0
# ORDS_URL=https://download.oracle.com/otn_software/java/ords/ords-${ORDS_VERSION}.zip

# Oracle JDK 21 LTS (latest alias — OCI 워크로드는 OTN 라이선스로 무료)
JDK_MAJOR=21
JDK_URL=https://download.oracle.com/java/${JDK_MAJOR}/latest/jdk-${JDK_MAJOR}_linux-x64_bin.tar.gz
# 버전 고정용 (필요 시):
# JDK_URL=https://download.oracle.com/java/21/archive/jdk-21.0.5_linux-x64_bin.tar.gz

DOWNLOAD_DIR=/var/tmp/ords-install

# --- 백엔드 DB (ADB 기준) ---
DB_KIND=adb                          # adb | onprem | rac
ADB_TNS=myadb_high                   # tnsnames.ora alias (= --wallet-service-name)
WALLET_PATH=/opt/oracle/wallet       # cwallet.sso 등 풀린 경로 (TNS_ADMIN 용)
WALLET_ZIP=/opt/oracle/wallet.zip    # ords install adb --wallet 가 요구하는 zip 파일
                                     # (비워두면 02_configure.sh 가 WALLET_PATH 를 zip 으로 묶음)
ADMIN_USER=ADMIN
ADMIN_PASSWORD=                      # 비워두면 run.sh가 read -s 로 프롬프트
ORDS_DB_USER=ORDS_PUBLIC_USER2
ORDS_DB_USER_PASSWORD=
ORDS_GATEWAY_USER=ORDS_PLSQL_GATEWAY2
ORDS_GATEWAY_USER_PASSWORD=

# --- ORDS 풀(pool) 설정 ---
POOL_NAME=adb_default
JDBC_INITIAL_LIMIT=5
JDBC_MAX_LIMIT=25                    # 노드당. (MaxLimit × 노드수) ≤ DB 세션한도

# --- 실행 모드 ---
ORDS_PORT=8080                       # HTTP (LB 종단 구성에서는 이걸 LB backend로)
# HTTPS 직접 종단이 필요하면 docs/05-cert-from-oci.md §5.5 참고
# (이 경우 ORDS_PORT 를 그대로 두지 말고 8443 등으로 바꾸고 ords config set 으로 cert 지정)

# --- HA ---
HA_NODE_ROLE=primary                 # primary | secondary
HA_NODES="10.0.1.11 10.0.1.12"       # 전 노드 IP (LB backend로 등록)

# --- OCI (Terraform LB 트랙 & Certificate Service) ---
OCI_REGION=                          # 예: ap-seoul-1 (비워두면 ~/.oci/config 의 DEFAULT 프로파일 region 사용)
OCI_COMPARTMENT_OCID=

# --- Network 모드 (둘 중 하나) ---
# (1) 신규 VCN 까지 terraform 으로 생성: OCI_CREATE_NETWORK=true (아래 OCI_LB_SUBNET_OCID 무시됨)
# (2) 기존 VCN/Subnet 사용:           OCI_CREATE_NETWORK=false + OCI_LB_SUBNET_OCID=ocid1.subnet...
OCI_CREATE_NETWORK=false
OCI_LB_SUBNET_OCID=
OCI_VCN_CIDR=10.99.0.0/16            # CREATE_NETWORK=true 일 때만 사용
OCI_PUBLIC_SUBNET_CIDR=10.99.1.0/24
OCI_SSH_INGRESS_CIDR=0.0.0.0/0       # SSH(22) 허용 source. 운영은 회사망/Bastion IP 로 좁힐 것
# (VCN OCID 는 LB 만 만들 때 불필요. NSG/Security List 자동화 추가하면 그때 OCI_VCN_OCID 도입)
LB_SHAPE=flexible                    # flexible | 10Mbps | 100Mbps | 400Mbps
LB_BANDWIDTH_MIN=10
LB_BANDWIDTH_MAX=100
LB_IS_PRIVATE=false                  # 인터넷 노출이면 false
LB_HEALTHCHECK_PATH=/ords/_/landing

# OCI Certificate Service — 두 가지 중 택1
#  A) 이미 OCI Cert Service에 등록된 cert OCID 가 있다면:
OCI_CERT_OCID=
#  B) 사설/외부 발급 인증서를 새로 import 하는 경우 → 아래 PEM 경로 채움
TLS_CERT_PEM=/etc/ords/tls/cert.pem          # 서버 인증서
TLS_KEY_PEM=/etc/ords/tls/privkey.pem        # 개인키 (암호화 X)
TLS_CHAIN_PEM=/etc/ords/tls/chain.pem        # 중간/루트 체인 (없으면 공란)
OCI_CERT_NAME=ords-private-cert              # OCI Cert Service에 등록될 이름

# --- Vector demo (./run.sh vector-demo) ---
# 기존에 설치된 ORDS + ADB 환경 위에 vector 검색용 스키마/모듈을 발행한다.
# 자세한 설명은 docs/07-vector-rest.md 참고.
VECTOR_DEMO_USER=VECTOR_DEMO                 # 생성될 데모 스키마 (이미 있으면 권한만 갱신)
VECTOR_DEMO_PASSWORD=                        # 비워두면 run.sh 가 read -s 로 프롬프트
                                             # ADB 정책: 12자 이상, 대소문자/숫자/특수문자 포함

# OCI GenAI 임베딩 — DBMS_VECTOR.UTL_TO_EMBEDDING (provider=ocigenai) 경로 ----
# 02_credential.sql 단계:
#   DBMS_VECTOR_CHAIN.CREATE_CREDENTIAL 로 OCI native API key 등록
#   (DBMS_VECTOR(.UTL_TO_EMBEDDING) 는 DBMS_VECTOR_CHAIN namespace 의 credential 만 lookup)
# 04_seed / 05_ords_publish / 06_test 는
#   DBMS_VECTOR.UTL_TO_EMBEDDING(data, json(params)) 호출.
#   params 안에 provider=ocigenai, url, model 인라인 지정.
#
# 기본 모델은 cohere.embed-v4.0 (multilingual, 기본 1536-dim).
# OCI_GENAI_DIM 은 컬럼 차원(03_schema.sql) 과 반드시 일치해야 함 —
# v4 는 Matryoshka 로 256/512/1024/1536 선택 가능, 변경 시 cleanup 후 재셋업.
OCI_GENAI_CRED_NAME=OCI_GENAI_CRED
OCI_GENAI_MODEL=cohere.embed-v4.0
OCI_GENAI_DIM=1536                                                # cohere.embed-v4.0 default. 256/512/1024/1536 중 선택 (스키마 컬럼 차원과 일치해야 함)
OCI_GENAI_URL=https://inference.generativeai.${OCI_REGION}.oci.oraclecloud.com/20231130/actions/embedText
OCI_GENAI_HOST=inference.generativeai.${OCI_REGION}.oci.oraclecloud.com   # 01_admin_setup.sql 의 network ACL 등록 대상

# OCI native auth (API key) — ~/.oci/config 의 [DEFAULT] 와 동일한 값 ----
# 콘솔 > 프로필 > User Settings > API Keys 에서 키페어 생성 후 fingerprint 확인.
# Tenancy/User OCID 도 같은 화면에서 복사.
#  - 사전 권한: IAM 사용자에게 "manage generative-ai-family" 또는 최소한
#    "use generative-ai-family in compartment <X>" 정책 부여 필요.
#  - 키 생성 예: oci setup keys 또는 콘솔 UI 에서 API Key 추가 (~/.oci 에 PEM 떨어짐).
#  - OCI_COMPARTMENT_OCID 는 위 LB 섹션과 동일 변수 재사용 (GenAI 서비스 접근 가능한 compartment).
OCI_USER_OCID=
OCI_TENANCY_OCID=
OCI_KEY_FINGERPRINT=
OCI_API_KEY_PEM=/Users/your-name/.oci/oci_api_key.pem   # 절대 경로. 600 권한 권장
# 08_vector_demo.sh 가 위 PEM 파일을 읽어 BEGIN/END/개행 제거한 본문을
# DEFINE 으로 sqlcl 에 주입 → DBMS_VECTOR_CHAIN.CREATE_CREDENTIAL 에 전달.

# (선택) ONNX in-DB 임베딩 — './run.sh vector-demo onnx' 사용 시에만 필요 ----
# 기본 플로우는 GenAI 서버측 임베딩이므로 비워둬도 됨.
# 자체 변환한 ONNX 모델을 OCI Object Storage 에 올리고 PAR URL 발급:
VECTOR_MODEL_NAME=DOC_MODEL                  # DB 안에서 ONNX 모델 별칭
VECTOR_MODEL_URI=                            # PAR URL (zip)
VECTOR_MODEL_FILE=                           # zip 파일명
# 참고: Oracle 공식 OML-Resources 버킷의 공개 PAR 은 회전/만료되는 경우가 있어
# 기본 플로우에서 제외됨. 자세한 절차는 docs/07-vector-rest.md §7.7 참고.
