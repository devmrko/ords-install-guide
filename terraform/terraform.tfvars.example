# 이 파일은 참조용. 실제 값은 06_lb_terraform.sh 가 .env 에서 TF_VAR_* 로 주입합니다.
# terraform 단독 실행할 때만 이 파일을 복사해서 사용:
#   cp terraform.tfvars.example terraform.tfvars

compartment_ocid = "ocid1.compartment.oc1..xxxx"
subnet_ocid      = "ocid1.subnet.oc1..xxxx"

ords_nodes        = "10.0.1.11 10.0.1.12"
ords_port         = 8080
healthcheck_path  = "/ords/_/landing"

lb_shape      = "flexible"
lb_bw_min     = 10
lb_bw_max     = 100
lb_is_private = false

# --- 인증서 ---
import_cert = true               # false 면 cert_ocid 만 사용
cert_ocid   = ""                 # import_cert=false 일 때 채움
cert_name   = "ords-private-cert"
# 아래는 셸에서 TF_VAR_cert_pem 등으로 주입하는 게 안전 (tfvars 평문 X)
cert_pem  = ""
key_pem   = ""
chain_pem = ""
